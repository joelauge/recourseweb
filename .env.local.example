# Stripe publishable key (starts with pk_live_ or pk_test_)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Base URL for the backend API. 
# Leave empty for local development (Vite will proxy to localhost:3001)
# For production (GitHub Pages + Cloudflare Workers), set this to your Worker URL
VITE_API_BASE_URL=https://knowdrive-api.your-subdomain.workers.dev

# --- DEPLOYMENT INSTRUCTIONS ---
# 1. Cloudflare Worker:
#    - Set STRIPE_SECRET_KEY in Cloudflare: `wrangler secret put STRIPE_SECRET_KEY`
#    - Deploy: `npm run worker:deploy`
# 2. GitHub Pages:
#    - Set VITE_API_BASE_URL to your worker URL in your GitHub Actions or local environment before building.
#    - Build: `npm run build`
